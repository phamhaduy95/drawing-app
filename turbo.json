{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"]
		},
		"test:ci": {
			"dependsOn": []
		},
		"type-check": {
			"dependsOn": []
		},
		"lint": {
			"dependsOn": []
		},
		"format": {
			"dependsOn": []
		},
		"dev": {
			"persistent": true,
			"cache": false
		}
	}
}
